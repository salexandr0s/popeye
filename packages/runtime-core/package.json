{
  "name": "@popeye/runtime-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@popeye/contracts": "workspace:*",
    "@popeye/engine-pi": "workspace:*",
    "@popeye/instructions": "workspace:*",
    "@popeye/memory": "workspace:*",
    "@popeye/observability": "workspace:*",
    "@popeye/receipts": "workspace:*",
    "@popeye/scheduler": "workspace:*",
    "@popeye/sessions": "workspace:*",
    "@popeye/workspace": "workspace:*",
    "@popeye/cap-files": "workspace:*",
    "@popeye/cap-email": "workspace:*",
    "@popeye/cap-github": "workspace:*",
    "@popeye/cap-calendar": "workspace:*",
    "@popeye/cap-todos": "workspace:*",
    "@popeye/cap-people": "workspace:*",
    "@popeye/cap-finance": "workspace:*",
    "@popeye/cap-medical": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "safe-regex2": "^4.0.0"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json --pretty false",
    "clean": "find src -type f \\( -name '*.js' -o -name '*.js.map' -o -name '*.d.ts' -o -name '*.d.ts.map' \\) -delete 2>/dev/null || true; rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc -b tsconfig.build.json --pretty false"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
