{
  "name": "@popeye/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@popeye/contracts": "workspace:*"
  },
  "devDependencies": {
    "@popeye/control-api": "workspace:*",
    "@popeye/runtime-core": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json --pretty false",
    "clean": "find src -type f \\( -name '*.js' -o -name '*.js.map' -o -name '*.d.ts' -o -name '*.d.ts.map' \\) -delete 2>/dev/null || true; rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc -b --pretty false"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
