{
  "name": "@popeye/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json --pretty false",
    "clean": "find src -type f \\( -name '*.js' -o -name '*.js.map' -o -name '*.d.ts' -o -name '*.d.ts.map' \\) -delete 2>/dev/null || true; rm -rf dist *.tsbuildinfo",
    "start": "tsx src/index.ts",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@fastify/static": "^8.1.0",
    "@popeye/api-client": "workspace:*",
    "@popeye/control-api": "workspace:*",
    "@popeye/observability": "workspace:*",
    "@popeye/runtime-core": "workspace:*",
    "@popeye/telegram": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
